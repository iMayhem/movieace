{
  "name": "movieace-vps-resolver",
  "version": "1.0.0",
  "description": "High-performance Node.js metadata resolver for Moviebox API streaming",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop movieace-resolver",
    "pm2:restart": "pm2 restart movieace-resolver",
    "pm2:logs": "pm2 logs movieace-resolver",
    "pm2:status": "pm2 status"
